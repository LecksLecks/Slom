//@version=6
// =============================================================================
// СЛОМ ТРЕНДА v11 — STRATEGY-КОМПАНЬОН для бэктеста
//
// Назначение: прогонять ту же логику сигналов, что и индикатор
// "Слом тренда (по методичке) v11", но как strategy() — с реальными входами
// и выходами по стоп/тейку, чтобы мерить win rate / PF / просадку и свипать
// матрицу фильтров (ретест, мин. высота зоны, кулдаун — по отдельности и
// вместе). Сигналы и уровни стоп/тейка байт-в-байт совпадают с индикатором:
//
//   - структура: локальные/глобальные пивоты (та же зона = последний пивот);
//   - закреп: refMode / импульс / полнотелые подряд / окно / направление;
//   - фильтры: объём, EMA-скор, сессия, сквиз, мин. высота зоны;
//   - ретест с отбоем (с багфиксом: бар взведения пропускается);
//   - скор n/m, дедуп ЛОК↔ГЛОБ (nearGlob), кулдаун одного направления;
//   - стоп = дальняя граница сломанной зоны ∓ slBuffer×ATR14, тейк по R:R —
//     ровно те уровни, что рисует группа "9." индикатора.
//
// Что НЕ перенесено (только оформление, на сигналы не влияет): метки
// экстремумов HH/LH, боксы зон, линии уровней, панель тренда/воронки,
// MACD-дивергенция (в v11 она информационная и сигналы не режет),
// счётчики воронки.
//
// Как читать бэктест:
//   1. Базовый прогон = «чистый сигнал» (11% WR / PF 0.375 из шапки
//      индикатора): все доп. фильтры ВЫКЛ и «Торговать слабые» ВКЛ. Важно:
//      проверка «воздух» (слом не обновил экстремум прошлого в ту же сторону)
//      активна всегда и без тумблера, поэтому при выключенном «Торговать
//      слабые» лесенка-сигналы уже отсеиваются — это НЕ чистый базовый прогон.
//   2. Включать по одному: «Торговать слабые» ВЫКЛ (= фильтр воздуха),
//      «Ретест», «Мин. высота зоны», «Кулдаун», EMA-скор. Смотреть, что
//      двигает PF/WR и сколько сделок остаётся (Total Trades).
//   3. Лучшие одиночные — комбинировать. Цель: PF > 1 при осмысленном числе
//      сделок (не 3 штуки на всей истории).
//
// ВАЖНО: фиктивного «предсказания» нет — пивот подтверждается через lookback
// баров, вход возможен только на подтверждённом баре (barstate.isconfirmed),
// заявка исполняется на открытии следующего бара. Repaint отсутствует.
// =============================================================================

// Капитал, размер позиции и комиссия заданы константами (этот Pine требует
// const в декларации strategy(), input там не принимается). Их всё равно
// удобнее менять во вкладке «Свойства» (Properties) тестера стратегий — она
// переопределяет значения из кода без правки файла.
strategy("Слом тренда v11 — strategy", "СЛОМ v11s", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10, commission_type = strategy.commission.percent, commission_value = 0.04, pyramiding = 0, process_orders_on_close = false, max_labels_count = 200)

G0 = "0. Бэктест"
tradeLong  = input.bool(true,  "Лонги", group = G0)
tradeShort = input.bool(true,  "Шорты", group = G0)
tradeLoc   = input.bool(true,  "Торговать локальные сломы", group = G0)
tradeGlob  = input.bool(true,  "Торговать глобальные сломы", group = G0)
tradeWeak  = input.bool(false, "Торговать слабые (скор ниже полного)", group = G0)
onlyFlat   = input.bool(true,  "Входить только при отсутствии позиции", group = G0, tooltip = "Каждый сигнал = одна сделка до своего стопа/тейка. Выкл — глобальный сигнал разворачивает позицию.")

// ─────────────────────────────────────────────────────────────────────────────
G1 = "1. Структура"
locLB  = input.int(5,  "Локальный хай/лой: lookback", minval = 2, group = G1)
globLB = input.int(20, "Глобальный хай/лой: lookback", minval = 3, group = G1)

G2 = "2. Закреп"
refMode    = input.string("Тело + подтверждение тенью", "Точка отсчёта пробоя", options = ["Конец тени (строго)", "Тело (мягко, слом внутри зоны)", "Тело + подтверждение тенью"], group = G2)
useImpulse = input.bool(true, "Импульсный закреп (одна свеча)", group = G2)
impulseATR = input.float(1.0, "Импульс: тело ≥ × ATR14", minval = 0.3, step = 0.1, group = G2)
strictMode = input.bool(true, "Полнотелые — строго ПОДРЯД", group = G2)
holdBars   = input.int(2, "Полнотелых свечей за зоной", minval = 1, maxval = 10, group = G2)
holdWindow = input.int(8, "Окно закрепа, баров", minval = 2, group = G2)
bodyRatio  = input.float(0.5, "Полнотелая свеча: тело ≥ доля диапазона", minval = 0.1, maxval = 1.0, step = 0.05, group = G2)
requireDir = input.bool(true, "Свечи закрепа — в сторону слома", group = G2)

G3 = "3. Дубли ЛОК/ГЛОБ"
dupATR    = input.float(0.5, "Уровни считать одним, если ближе × ATR14", minval = 0.0, step = 0.1, group = G3)
dupWindow = input.int(10, "Глобальная зона считается «свежей» в пределах, баров", minval = 0, group = G3)

G6 = "4. Доп. фильтры (ложные сломы)"
useVolFilter = input.bool(false, "Фильтр по объёму", group = G6)
volLen       = input.int(20, "Объём: период SMA", minval = 2, group = G6)
volMult      = input.float(1.2, "Объём: множитель от SMA", minval = 0.1, step = 0.1, group = G6)

useEmaFilter = input.bool(false, "Слом против EMA — снижает скор", group = G6)

useRetest     = input.bool(false, "Требовать ретест с отбоем перед сигналом", group = G6)
retestATR     = input.float(1.0, "Ретест: допуск от уровня, × ATR14", minval = 0.1, step = 0.1, group = G6)
retestWindow  = input.int(10, "Ретест: окно ожидания, баров", minval = 2, group = G6)

useSession = input.bool(false, "Фильтр по сессии — не начинать пробой вне сессии", group = G6)
sessTime   = input.session("0800-2200", "Разрешённая сессия (UTC)", group = G6)

useSqueezeFilter = input.bool(false, "Фильтр сжатия волатильности — не начинать пробой в сквизе", group = G6)
atrSmaLen        = input.int(50, "Волатильность: период средней ATR", minval = 5, group = G6)
squeezeMult      = input.float(0.7, "Сквиз, если ATR14 < × средней ATR", minval = 0.1, step = 0.05, group = G6)

useMinZone   = input.bool(false, "Мин. высота зоны — не начинать пробой микрозоны", group = G6)
minZoneATR   = input.float(0.5, "Мин. высота зоны, × ATR14", minval = 0.05, step = 0.05, group = G6)

useCooldown  = input.bool(false, "Кулдаун между сигналами одного направления", group = G6)
cooldownBars = input.int(10, "Кулдаун, баров", minval = 1, group = G6)

G9 = "5. Стоп/тейк"
rrRatio   = input.float(3.0, "R:R", minval = 0.5, step = 0.5, group = G9)
slBuffer  = input.float(0.3, "Стоп: доп. буфер за зоной, × ATR14", minval = 0, step = 0.1, group = G9)
showLvls  = input.bool(true, "Рисовать стоп/тейк входа", group = G9)

bullCol = input.color(#26a69a, "Bull", inline = "c", group = G9)
bearCol = input.color(#ef5350, "Bear", inline = "c", group = G9)

strictRef  = refMode == "Конец тени (строго)"
needWickOK = refMode == "Тело + подтверждение тенью"

// ─────────────────────────────────────────────────────────────────────────────
emaFast  = ta.ema(close, 50)
emaSlow  = ta.ema(close, 200)
emaTrend = emaFast > emaSlow and close > emaFast ? 1 : emaFast < emaSlow and close < emaFast ? -1 : 0

atr14 = ta.atr(14)

phLoc  = ta.pivothigh(high, locLB,  locLB)
plLoc  = ta.pivotlow(low,   locLB,  locLB)
phGlob = ta.pivothigh(high, globLB, globLB)
plGlob = ta.pivotlow(low,   globLB, globLB)

bodySz   = math.abs(close - open)
rng      = high - low
fullBody = rng > 0 and bodySz / rng >= bodyRatio
impBody  = bodySz >= impulseATR * atr14

// ta.sma считаем безусловно (в глобальной переменной), иначе внутри «or» он
// может вызываться не на каждом баре — CW10002
volSma   = ta.sma(volume, volLen)
volOK    = not useVolFilter or volume >= volSma * volMult

holdUpC  = fullBody and (not requireDir or close > open) and volOK
holdDnC  = fullBody and (not requireDir or close < open) and volOK
impUpC   = useImpulse and impBody and close > open and volOK
impDnC   = useImpulse and impBody and close < open and volOK

sessOK = not useSession or not timeframe.isintraday or not na(time(timeframe.period, sessTime, "UTC"))

atrSMA    = ta.sma(atr14, atrSmaLen)
squeezeOK = not useSqueezeFilter or atr14 >= atrSMA * squeezeMult

startOK = sessOK and squeezeOK

minZoneOK(float top, float bot) =>
    not useMinZone or (not na(top) and not na(bot) and top - bot >= minZoneATR * atr14)

// ЗОНЫ (последний пивот; классификация HH/LH на сигналы не влияет) -------------
var float lhTop = na
var float lhBot = na
var float ghTop = na
var float ghBot = na
var float llBot = na
var float llTop = na
var float glBot = na
var float glTop = na
var int   ghBar = na
var int   glBar = na

// ПОПЫТКИ ---------------------------------------------------------------------
var bool  aLHon = false
var float aLHref = na
var float aLHfar = na
var float aLHwick = na
var bool  aLHwickOK = false
var int   aLHbar = na
var int   aLHcnt = 0

var bool  aGHon = false
var float aGHref = na
var float aGHfar = na
var float aGHwick = na
var bool  aGHwickOK = false
var int   aGHbar = na
var int   aGHcnt = 0

var bool  aLLon = false
var float aLLref = na
var float aLLfar = na
var float aLLwick = na
var bool  aLLwickOK = false
var int   aLLbar = na
var int   aLLcnt = 0

var bool  aGLon = false
var float aGLref = na
var float aGLfar = na
var float aGLwick = na
var bool  aGLwickOK = false
var int   aGLbar = na
var int   aGLcnt = 0

var float lhBroken = na
var float lhBrokenFar = na
var float ghBroken = na
var float ghBrokenFar = na
var float llBroken = na
var float llBrokenFar = na
var float glBroken = na
var float glBrokenFar = na

var int   locLastDir = 0
var float locLastLvl = na
var int   globLastDir = 0
var float globLastLvl = na

// кулдаун: бар последнего эмитированного сигнала каждого типа
var int lastSigLocUpBar  = na
var int lastSigLocDnBar  = na
var int lastSigGlobUpBar = na
var int lastSigGlobDnBar = na

// РЕТЕСТ ----------------------------------------------------------------------
var bool  rtLHon = false
var float rtLHlvl = na
var int   rtLHbar = na
var bool  rtLHtouched = false
var float rtLHfar = na

var bool  rtLLon = false
var float rtLLlvl = na
var int   rtLLbar = na
var bool  rtLLtouched = false
var float rtLLfar = na

var bool  rtGHon = false
var float rtGHlvl = na
var int   rtGHbar = na
var bool  rtGHtouched = false
var float rtGHfar = na

var bool  rtGLon = false
var float rtGLlvl = na
var int   rtGLbar = na
var bool  rtGLtouched = false
var float rtGLfar = na

// сигналы слома этого бара
bool sigLocUp  = false
bool sigLocDn  = false
bool sigGlobUp = false
bool sigGlobDn = false
float sLvlLocUp = na
float sLvlLocDn = na
float sLvlGlobUp = na
float sLvlGlobDn = na
float sFarLocUp = na
float sFarLocDn = na
float sFarGlobUp = na
float sFarGlobDn = na

// итоговые решения на вход (глоб приоритетнее лок — перезаписывает)
bool  entLong  = false
bool  entShort = false
float slLong = na
float tpLong = na
float slShort = na
float tpShort = na

if barstate.isconfirmed

    // ===== ОБНОВЛЕНИЕ ЗОН ===================================================
    if not na(phLoc)
        lhTop := high[locLB]
        lhBot := math.max(open[locLB], close[locLB])
    if not na(plLoc)
        llBot := low[locLB]
        llTop := math.min(open[locLB], close[locLB])
    if not na(phGlob)
        ghTop := high[globLB]
        ghBot := math.max(open[globLB], close[globLB])
        ghBar := bar_index
    if not na(plGlob)
        glBot := low[globLB]
        glTop := math.min(open[globLB], close[globLB])
        glBar := bar_index

    // ===== СБРОС «УЖЕ СЛОМАН» ===============================================
    if not na(lhBroken) and not na(lhBrokenFar) and close < lhBrokenFar
        lhBroken := na
        lhBrokenFar := na
        rtLHon := false
    if not na(ghBroken) and not na(ghBrokenFar) and close < ghBrokenFar
        ghBroken := na
        ghBrokenFar := na
        rtGHon := false
    if not na(llBroken) and not na(llBrokenFar) and close > llBrokenFar
        llBroken := na
        llBrokenFar := na
        rtLLon := false
    if not na(glBroken) and not na(glBrokenFar) and close > glBrokenFar
        glBroken := na
        glBrokenFar := na
        rtGLon := false

    zLH = strictRef ? lhTop : lhBot
    zGH = strictRef ? ghTop : ghBot
    zLL = strictRef ? llBot : llTop
    zGL = strictRef ? glBot : glTop

    // ===== ПЕРЕПРИВЯЗКА ======================================================
    if aLHon and not na(zLH) and zLH > aLHref
        aLHon := false
        aLHcnt := 0
    if aGHon and not na(zGH) and zGH > aGHref
        aGHon := false
        aGHcnt := 0
    if aLLon and not na(zLL) and zLL < aLLref
        aLLon := false
        aLLcnt := 0
    if aGLon and not na(zGL) and zGL < aGLref
        aGLon := false
        aGLcnt := 0

    // ===== ЗАКРЕП: ЛОК ВВЕРХ (LH) ==========================================
    refLH = aLHon ? aLHref : zLH
    if not na(refLH) and (na(lhBroken) or refLH != lhBroken)
        if close > refLH and (aLHon or (startOK and minZoneOK(lhTop, lhBot)))
            if not aLHon
                aLHon := true
                aLHref := refLH
                aLHfar := lhBot
                aLHwick := lhTop
                aLHwickOK := false
                aLHbar := bar_index
                aLHcnt := 0
            if close > aLHwick
                aLHwickOK := true
            if impUpC
                aLHcnt := holdBars
            else if holdUpC
                aLHcnt += 1
            else if strictMode
                aLHcnt := 0
            if aLHcnt >= holdBars and (not needWickOK or aLHwickOK)
                lhBroken := aLHref
                lhBrokenFar := aLHfar
                if useRetest
                    rtLHon := true
                    rtLHlvl := aLHref
                    rtLHbar := bar_index
                    rtLHtouched := false
                    rtLHfar := aLHfar
                else
                    sigLocUp := true
                    sLvlLocUp := aLHref
                    sFarLocUp := aLHfar
                aLHon := false
                aLHcnt := 0
            else if bar_index - aLHbar >= holdWindow
                aLHon := false
                aLHcnt := 0
        else
            aLHon := false
            aLHcnt := 0

    // ===== ЗАКРЕП: ЛОК ВНИЗ (LL) ===========================================
    refLL = aLLon ? aLLref : zLL
    if not na(refLL) and (na(llBroken) or refLL != llBroken)
        if close < refLL and (aLLon or (startOK and minZoneOK(llTop, llBot)))
            if not aLLon
                aLLon := true
                aLLref := refLL
                aLLfar := llTop
                aLLwick := llBot
                aLLwickOK := false
                aLLbar := bar_index
                aLLcnt := 0
            if close < aLLwick
                aLLwickOK := true
            if impDnC
                aLLcnt := holdBars
            else if holdDnC
                aLLcnt += 1
            else if strictMode
                aLLcnt := 0
            if aLLcnt >= holdBars and (not needWickOK or aLLwickOK)
                llBroken := aLLref
                llBrokenFar := aLLfar
                if useRetest
                    rtLLon := true
                    rtLLlvl := aLLref
                    rtLLbar := bar_index
                    rtLLtouched := false
                    rtLLfar := aLLfar
                else
                    sigLocDn := true
                    sLvlLocDn := aLLref
                    sFarLocDn := aLLfar
                aLLon := false
                aLLcnt := 0
            else if bar_index - aLLbar >= holdWindow
                aLLon := false
                aLLcnt := 0
        else
            aLLon := false
            aLLcnt := 0

    // ===== ЗАКРЕП: ГЛОБ ВВЕРХ (GH) =========================================
    refGH = aGHon ? aGHref : zGH
    if not na(refGH) and (na(ghBroken) or refGH != ghBroken)
        if close > refGH and (aGHon or (startOK and minZoneOK(ghTop, ghBot)))
            if not aGHon
                aGHon := true
                aGHref := refGH
                aGHfar := ghBot
                aGHwick := ghTop
                aGHwickOK := false
                aGHbar := bar_index
                aGHcnt := 0
            if close > aGHwick
                aGHwickOK := true
            if impUpC
                aGHcnt := holdBars
            else if holdUpC
                aGHcnt += 1
            else if strictMode
                aGHcnt := 0
            if aGHcnt >= holdBars and (not needWickOK or aGHwickOK)
                ghBroken := aGHref
                ghBrokenFar := aGHfar
                if useRetest
                    rtGHon := true
                    rtGHlvl := aGHref
                    rtGHbar := bar_index
                    rtGHtouched := false
                    rtGHfar := aGHfar
                else
                    sigGlobUp := true
                    sLvlGlobUp := aGHref
                    sFarGlobUp := aGHfar
                aGHon := false
                aGHcnt := 0
            else if bar_index - aGHbar >= holdWindow
                aGHon := false
                aGHcnt := 0
        else
            aGHon := false
            aGHcnt := 0

    // ===== ЗАКРЕП: ГЛОБ ВНИЗ (GL) ==========================================
    refGL = aGLon ? aGLref : zGL
    if not na(refGL) and (na(glBroken) or refGL != glBroken)
        if close < refGL and (aGLon or (startOK and minZoneOK(glTop, glBot)))
            if not aGLon
                aGLon := true
                aGLref := refGL
                aGLfar := glTop
                aGLwick := glBot
                aGLwickOK := false
                aGLbar := bar_index
                aGLcnt := 0
            if close < aGLwick
                aGLwickOK := true
            if impDnC
                aGLcnt := holdBars
            else if holdDnC
                aGLcnt += 1
            else if strictMode
                aGLcnt := 0
            if aGLcnt >= holdBars and (not needWickOK or aGLwickOK)
                glBroken := aGLref
                glBrokenFar := aGLfar
                if useRetest
                    rtGLon := true
                    rtGLlvl := aGLref
                    rtGLbar := bar_index
                    rtGLtouched := false
                    rtGLfar := aGLfar
                else
                    sigGlobDn := true
                    sLvlGlobDn := aGLref
                    sFarGlobDn := aGLfar
                aGLon := false
                aGLcnt := 0
            else if bar_index - aGLbar >= holdWindow
                aGLon := false
                aGLcnt := 0
        else
            aGLon := false
            aGLcnt := 0

    // ===== РЕТЕСТ (бар взведения пропускается — багфикс) ====================
    if rtLHon and bar_index > rtLHbar
        if not rtLHtouched and low <= rtLHlvl + retestATR * atr14
            rtLHtouched := true
        if rtLHtouched and close > rtLHlvl
            sigLocUp := true
            sLvlLocUp := rtLHlvl
            sFarLocUp := rtLHfar
            rtLHon := false
        else if bar_index - rtLHbar >= retestWindow
            rtLHon := false

    if rtLLon and bar_index > rtLLbar
        if not rtLLtouched and high >= rtLLlvl - retestATR * atr14
            rtLLtouched := true
        if rtLLtouched and close < rtLLlvl
            sigLocDn := true
            sLvlLocDn := rtLLlvl
            sFarLocDn := rtLLfar
            rtLLon := false
        else if bar_index - rtLLbar >= retestWindow
            rtLLon := false

    if rtGHon and bar_index > rtGHbar
        if not rtGHtouched and low <= rtGHlvl + retestATR * atr14
            rtGHtouched := true
        if rtGHtouched and close > rtGHlvl
            sigGlobUp := true
            sLvlGlobUp := rtGHlvl
            sFarGlobUp := rtGHfar
            rtGHon := false
        else if bar_index - rtGHbar >= retestWindow
            rtGHon := false

    if rtGLon and bar_index > rtGLbar
        if not rtGLtouched and high >= rtGLlvl - retestATR * atr14
            rtGLtouched := true
        if rtGLtouched and close < rtGLlvl
            sigGlobDn := true
            sLvlGlobDn := rtGLlvl
            sFarGlobDn := rtGLfar
            rtGLon := false
        else if bar_index - rtGLbar >= retestWindow
            rtGLon := false

    // ===== СИГНАЛ → ВХОД (те же гейты, что метки/алерты индикатора) =========
    // ЛОК ВВЕРХ
    if sigLocUp
        lvl = sLvlLocUp
        air = locLastDir == 1 and not na(locLastLvl) ? lvl <= locLastLvl : false
        locLastDir := 1
        locLastLvl := lvl
        nearGlob = not na(zGH) and math.abs(lvl - zGH) <= dupATR * atr14 and not na(ghBar) and (bar_index - ghBar <= dupWindow)
        emaBad   = useEmaFilter and emaTrend == -1
        totalChk = 1 + (useEmaFilter ? 1 : 0)
        passChk  = (air ? 0 : 1) + (useEmaFilter ? (emaBad ? 0 : 1) : 0)
        full     = passChk == totalChk
        cooldownOK = not useCooldown or na(lastSigLocUpBar) or (bar_index - lastSigLocUpBar >= cooldownBars)
        wouldTrade = tradeLoc and not nearGlob and (full or tradeWeak)
        if wouldTrade and cooldownOK
            lastSigLocUpBar := bar_index
            sl = sFarLocUp - slBuffer * atr14
            if close - sl > 0
                entLong := true
                slLong := sl
                tpLong := close + (close - sl) * rrRatio

    // ЛОК ВНИЗ
    if sigLocDn
        lvl = sLvlLocDn
        air = locLastDir == -1 and not na(locLastLvl) ? lvl >= locLastLvl : false
        locLastDir := -1
        locLastLvl := lvl
        nearGlob = not na(zGL) and math.abs(lvl - zGL) <= dupATR * atr14 and not na(glBar) and (bar_index - glBar <= dupWindow)
        emaBad   = useEmaFilter and emaTrend == 1
        totalChk = 1 + (useEmaFilter ? 1 : 0)
        passChk  = (air ? 0 : 1) + (useEmaFilter ? (emaBad ? 0 : 1) : 0)
        full     = passChk == totalChk
        cooldownOK = not useCooldown or na(lastSigLocDnBar) or (bar_index - lastSigLocDnBar >= cooldownBars)
        wouldTrade = tradeLoc and not nearGlob and (full or tradeWeak)
        if wouldTrade and cooldownOK
            lastSigLocDnBar := bar_index
            sl = sFarLocDn + slBuffer * atr14
            if sl - close > 0
                entShort := true
                slShort := sl
                tpShort := close - (sl - close) * rrRatio

    // ГЛОБ ВВЕРХ (приоритет над лок — перезаписывает entLong)
    if sigGlobUp
        lvl = sLvlGlobUp
        air = globLastDir == 1 and not na(globLastLvl) ? lvl <= globLastLvl : false
        globLastDir := 1
        globLastLvl := lvl
        emaBad   = useEmaFilter and emaTrend == -1
        totalChk = 1 + (useEmaFilter ? 1 : 0)
        passChk  = (air ? 0 : 1) + (useEmaFilter ? (emaBad ? 0 : 1) : 0)
        full     = passChk == totalChk
        cooldownOK = not useCooldown or na(lastSigGlobUpBar) or (bar_index - lastSigGlobUpBar >= cooldownBars)
        wouldTrade = tradeGlob and (full or tradeWeak)
        if wouldTrade and cooldownOK
            lastSigGlobUpBar := bar_index
            sl = sFarGlobUp - slBuffer * atr14
            if close - sl > 0
                entLong := true
                slLong := sl
                tpLong := close + (close - sl) * rrRatio

    // ГЛОБ ВНИЗ
    if sigGlobDn
        lvl = sLvlGlobDn
        air = globLastDir == -1 and not na(globLastLvl) ? lvl >= globLastLvl : false
        globLastDir := -1
        globLastLvl := lvl
        emaBad   = useEmaFilter and emaTrend == 1
        totalChk = 1 + (useEmaFilter ? 1 : 0)
        passChk  = (air ? 0 : 1) + (useEmaFilter ? (emaBad ? 0 : 1) : 0)
        full     = passChk == totalChk
        cooldownOK = not useCooldown or na(lastSigGlobDnBar) or (bar_index - lastSigGlobDnBar >= cooldownBars)
        wouldTrade = tradeGlob and (full or tradeWeak)
        if wouldTrade and cooldownOK
            lastSigGlobDnBar := bar_index
            sl = sFarGlobDn + slBuffer * atr14
            if sl - close > 0
                entShort := true
                slShort := sl
                tpShort := close - (sl - close) * rrRatio

// ===== РАЗМЕЩЕНИЕ ЗАЯВОК ======================================================
// Лонг размещается первым: в редком конфликте (лонг и шорт в одном баре) при
// onlyFlat лонг займёт позицию, и шорт будет пропущен (не флэт).
flat = strategy.position_size == 0

if entLong and tradeLong and (not onlyFlat or flat)
    strategy.entry("L", strategy.long)
    strategy.exit("L x", from_entry = "L", stop = slLong, limit = tpLong)
    if showLvls
        label.new(bar_index, slLong, "SL", style = label.style_label_up, color = color.new(bearCol, 20), textcolor = color.white, size = size.tiny)

if entShort and tradeShort and (not onlyFlat or flat)
    strategy.entry("S", strategy.short)
    strategy.exit("S x", from_entry = "S", stop = slShort, limit = tpShort)
    if showLvls
        label.new(bar_index, slShort, "SL", style = label.style_label_down, color = color.new(bearCol, 20), textcolor = color.white, size = size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
plot(showLvls ? emaFast : na, "EMA 50",  color = color.new(#ffb74d, 0))
plot(showLvls ? emaSlow : na, "EMA 200", color = color.new(#7e57c2, 0), linewidth = 2)
