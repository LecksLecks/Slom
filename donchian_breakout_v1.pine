//@version=6
// =============================================================================
// DONCHIAN BREAKOUT v1 — трендовый пробой канала (turtle-style)
//
// Максимально простая трендовая стратегия: вход на пробое N-барового
// хай/лоя, выход — единственный ATR-трейлинг-стоп (chandelier). Никаких
// фильтров по EMA/объёму/HTF/сессиям — простота как осознанный дизайн-выбор
// ради устойчивости и низкого риска переобучения.
//
// Эдж-параметров всего 4 (реально тюнятся 2: dcLen и atrMult).
// =============================================================================
strategy("Donchian Breakout v1", "DONCH v1 [S]", overlay = true, pyramiding = 0, process_orders_on_close = true, calc_on_every_tick = false, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10, commission_type = strategy.commission.percent, commission_value = 0.05, slippage = 2, max_bars_back = 500)

// ─────────────────────────────────────────────────────────────────────────────
// ЭДЖ-ПАРАМЕТРЫ (минимум — см. документацию, почему их так мало)
G = "Стратегия"
dcLen    = input.int(20, "Донч. канал: длина пробоя, N баров", minval = 2, group = G, tooltip = "Классика turtle — 20. Основной тюнинг-параметр.")
atrMult  = input.float(3.0, "ATR-трейл: множитель стопа", minval = 0.5, step = 0.1, group = G, tooltip = "Chandelier-множитель. Шире = меньше выбивает, но больше отдаём на развороте.")
atrLen   = input.int(14, "ATR: период", minval = 1, group = G, tooltip = "Стандарт 14 — обычно НЕ трогать, оставлен как есть для честности выборки.")
tradeDir = input.string("Обе", "Направление", options = ["Обе", "Только лонг", "Только шорт"], group = G, tooltip = "У BTC исторический up-drift → лонг-онли часто лучше по risk-adjusted. Решает бэктест.")

// БЭКТЕСТ-ОКНО (НЕ эдж-параметры — только для OOS/walk-forward прогонов)
GD = "Бэктест-окно (не эдж-параметры)"
useDates  = input.bool(false, "Ограничить период входов", group = GD)
startDate = input.time(timestamp("2023-01-01 00:00 +0000"), "Начало", group = GD)
endDate   = input.time(timestamp("2026-01-01 00:00 +0000"), "Конец", group = GD)

// ─────────────────────────────────────────────────────────────────────────────
// РАСЧЁТ
atr = ta.atr(atrLen)

// Уровни канала по N ПРОШЛЫМ барам ([1] исключает текущий бар → без repaint)
upper = ta.highest(high, dcLen)[1]
lower = ta.lowest(low,  dcLen)[1]

canLong  = tradeDir != "Только шорт"
canShort = tradeDir != "Только лонг"
inWindow = not useDates or (time >= startDate and time <= endDate)

flat     = strategy.position_size == 0
longSig  = not na(upper) and close > upper
shortSig = not na(lower) and close < lower

longEntry  = flat and canLong  and longSig  and inWindow
shortEntry = flat and canShort and shortSig and inWindow

// ─────────────────────────────────────────────────────────────────────────────
// ВХОДЫ (на закрытии подтверждённого пробоя, process_orders_on_close)
if longEntry
    strategy.entry("Long", strategy.long)
if shortEntry
    strategy.entry("Short", strategy.short)

// ─────────────────────────────────────────────────────────────────────────────
// ВЫХОД — chandelier ATR-трейлинг-стоп (монотонный, единственный механизм)
var float longTrail  = na
var float shortTrail = na

inLong  = strategy.position_size > 0 or longEntry
inShort = strategy.position_size < 0 or shortEntry

if inLong
    ns = high - atrMult * atr
    longTrail := na(longTrail) ? ns : math.max(longTrail, ns)   // только вверх
    strategy.exit("Long exit", from_entry = "Long", stop = longTrail)
else
    longTrail := na

if inShort
    ns = low + atrMult * atr
    shortTrail := na(shortTrail) ? ns : math.min(shortTrail, ns) // только вниз
    strategy.exit("Short exit", from_entry = "Short", stop = shortTrail)
else
    shortTrail := na

// ─────────────────────────────────────────────────────────────────────────────
// ВИЗУАЛИЗАЦИЯ (только канал и активный стоп — ничего лишнего)
plot(upper, "Донч. верх", color = color.new(#26a69a, 30), linewidth = 1)
plot(lower, "Донч. низ",  color = color.new(#ef5350, 30), linewidth = 1)
plot(inLong ? longTrail : inShort ? shortTrail : na, "ATR-трейл-стоп", color = color.new(color.orange, 0), style = plot.style_linebr, linewidth = 2)
